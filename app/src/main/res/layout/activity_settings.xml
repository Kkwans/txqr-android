<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F5F5F5">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:gravity="center_vertical"
        android:background="#FFFFFF"
        android:paddingHorizontal="8dp"
        android:elevation="2dp">

        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:src="@drawable/ic_back"
            android:background="@drawable/bg_rounded_btn"
            android:contentDescription="返回"
            android:tint="#212121"
            android:scaleType="center"
            android:padding="10dp" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="设置"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="#212121"
            android:layout_marginStart="12dp" />
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- 文件保存 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_card"
                android:padding="16dp"
                android:layout_marginBottom="12dp"
                android:elevation="1dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="文件保存"
                    android:textColor="#1976D2"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.08"
                    android:layout_marginBottom="12dp" />

                <LinearLayout
                    android:id="@+id/saveDirRow"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:clickable="true"
                    android:focusable="true"
                    android:background="@drawable/bg_card_input"
                    android:padding="14dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="保存目录"
                        android:textColor="#212121"
                        android:textSize="15sp" />

                    <TextView
                        android:id="@+id/tvSaveDir"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="/Download/TXQR"
                        android:textColor="#9E9E9E"
                        android:textSize="13sp"
                        android:maxWidth="180dp"
                        android:maxLines="1"
                        android:ellipsize="middle" />

                    <TextView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:text="›"
                        android:textColor="#BDBDBD"
                        android:textSize="20sp"
                        android:gravity="center" />
                </LinearLayout>

                <Button
                    android:id="@+id/btnOpenSaveDir"
                    android:layout_width="match_parent"
                    android:layout_height="40dp"
                    android:text="📂 查看保存目录"
                    android:textSize="13sp"
                    android:layout_marginTop="8dp"
                    android:backgroundTint="#E3F2FD"
                    android:textColor="#1976D2" />
            </LinearLayout>

            <!-- 扫描设置 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_card"
                android:padding="16dp"
                android:layout_marginBottom="12dp"
                android:elevation="1dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="扫描设置"
                    android:textColor="#1976D2"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.08"
                    android:layout_marginBottom="12dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingVertical="12dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="仅扫描 QR 码"
                        android:textColor="#212121"
                        android:textSize="15sp" />

                    <ImageButton
                        android:id="@+id/btnHelpQrOnly"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/ic_help"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:scaleType="center"
                        android:contentDescription="帮助"
                        android:layout_marginEnd="8dp" />

                    <Switch
                        android:id="@+id/switchQrOnly"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:checked="true" />
                </LinearLayout>

                <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#F0F0F0" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingVertical="12dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="连续自动对焦"
                        android:textColor="#212121"
                        android:textSize="15sp" />

                    <ImageButton
                        android:id="@+id/btnHelpAutoFocus"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/ic_help"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:scaleType="center"
                        android:contentDescription="帮助"
                        android:layout_marginEnd="8dp" />

                    <Switch
                        android:id="@+id/switchAutoFocus"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:checked="true" />
                </LinearLayout>

                <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#F0F0F0" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingVertical="12dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="扫描区域提示"
                        android:textColor="#212121"
                        android:textSize="15sp" />

                    <ImageButton
                        android:id="@+id/btnHelpOverlay"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/ic_help"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:scaleType="center"
                        android:contentDescription="帮助"
                        android:layout_marginEnd="8dp" />

                    <Switch
                        android:id="@+id/switchShowOverlay"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:checked="true" />
                </LinearLayout>
            </LinearLayout>

            <!-- 性能设置 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_card"
                android:padding="16dp"
                android:layout_marginBottom="12dp"
                android:elevation="1dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="性能设置"
                    android:textColor="#1976D2"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.08"
                    android:layout_marginBottom="12dp" />

                <LinearLayout
                    android:id="@+id/resolutionRow"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingVertical="12dp"
                    android:clickable="true"
                    android:focusable="true">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="分析分辨率"
                            android:textColor="#212121"
                            android:textSize="15sp" />
                    </LinearLayout>

                    <ImageButton
                        android:id="@+id/btnHelpResolution"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/ic_help"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:scaleType="center"
                        android:contentDescription="帮助"
                        android:layout_marginEnd="8dp" />

                    <TextView
                        android:id="@+id/tvResolution"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="640×480"
                        android:textColor="#1976D2"
                        android:textSize="14sp" />

                    <TextView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:text="›"
                        android:textColor="#BDBDBD"
                        android:textSize="20sp"
                        android:gravity="center" />
                </LinearLayout>

                <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#F0F0F0" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingVertical="12dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="始终显示进度卡片"
                        android:textColor="#212121"
                        android:textSize="15sp" />

                    <ImageButton
                        android:id="@+id/btnHelpAlwaysShow"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/ic_help"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:scaleType="center"
                        android:contentDescription="帮助"
                        android:layout_marginEnd="8dp" />

                    <Switch
                        android:id="@+id/switchAlwaysShowProgress"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:checked="false" />
                </LinearLayout>

                <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#F0F0F0" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingVertical="12dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="解码时显示进度卡片"
                        android:textColor="#212121"
                        android:textSize="15sp" />

                    <ImageButton
                        android:id="@+id/btnHelpProgress"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/ic_help"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:scaleType="center"
                        android:contentDescription="帮助"
                        android:layout_marginEnd="8dp" />

                    <Switch
                        android:id="@+id/switchShowProgress"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:checked="true" />
                </LinearLayout>
            </LinearLayout>

            <!-- 关于 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_card"
                android:padding="16dp"
                android:layout_marginBottom="12dp"
                android:elevation="1dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="关于"
                    android:textColor="#1976D2"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.08"
                    android:layout_marginBottom="12dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:padding="12dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="TXQR 接收器"
                        android:textColor="#212121"
                        android:textSize="18sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="v3.6.0 · 离线二维码文件传输"
                        android:textColor="#9E9E9E"
                        android:textSize="12sp"
                        android:layout_marginTop="4dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="作者: Kkwans"
                        android:textColor="#757575"
                        android:textSize="12sp"
                        android:layout_marginTop="8dp" />

                    <TextView
                        android:id="@+id/tvGithub"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="GitHub: Kkwans/txqr-android"
                        android:textColor="#1976D2"
                        android:textSize="12sp"
                        android:layout_marginTop="4dp"
                        android:clickable="true"
                        android:focusable="true" />
                </LinearLayout>
            </LinearLayout>

        </LinearLayout>
    </ScrollView>

</LinearLayout>
