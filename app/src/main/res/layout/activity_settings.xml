<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F5F5F5">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:gravity="center_vertical"
        android:background="#FFFFFF"
        android:paddingHorizontal="8dp"
        android:elevation="2dp">

        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:src="@drawable/ic_back"
            android:background="@drawable/bg_rounded_btn"
            android:contentDescription="返回"
            android:tint="#212121"
            android:scaleType="center"
            android:padding="10dp" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="设置"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="#212121"
            android:layout_marginStart="12dp" />
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- 文件保存 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_card"
                android:padding="16dp"
                android:layout_marginBottom="12dp"
                android:elevation="1dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="文件保存"
                    android:textColor="#1976D2"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.08"
                    android:layout_marginBottom="12dp" />

                <LinearLayout
                    android:id="@+id/saveDirRow"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:clickable="true"
                    android:focusable="true"
                    android:background="@drawable/bg_card_input"
                    android:padding="14dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="保存目录"
                        android:textColor="#212121"
                        android:textSize="15sp" />

                    <TextView
                        android:id="@+id/tvSaveDir"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="/Download/TXQR"
                        android:textColor="#9E9E9E"
                        android:textSize="13sp"
                        android:maxWidth="180dp"
                        android:maxLines="1"
                        android:ellipsize="middle" />

                    <TextView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:text="›"
                        android:textColor="#9E9E9E"
                        android:textSize="20sp"
                        android:gravity="center" />
                </LinearLayout>

                <Button
                    android:id="@+id/btnOpenSaveDir"
                    android:layout_width="match_parent"
                    android:layout_height="40dp"
                    android:text="📂 查看保存目录"
                    android:textSize="13sp"
                    android:layout_marginTop="8dp"
                    android:backgroundTint="#E3F2FD"
                    android:textColor="#1976D2" />
            </LinearLayout>

            <!-- 扫描设置 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_card"
                android:padding="16dp"
                android:layout_marginBottom="12dp"
                android:elevation="1dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="扫描设置"
                    android:textColor="#1976D2"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.08"
                    android:layout_marginBottom="4dp" />

                <!-- 仅扫描 QR 码 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <TextView
                            android:id="@+id/tvQrOnly"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="仅扫描 QR 码"
                            android:textColor="#212121"
                            android:textSize="15sp"
                            android:clickable="true"
                            android:focusable="true" />

                        <TextView
                            android:id="@+id/btnHelpQrOnly"
                            android:layout_width="16dp"
                            android:layout_height="16dp"
                            android:text="?"
                            android:textColor="#9E9E9E"
                            android:textSize="10sp"
                            android:gravity="center"
                            android:background="@drawable/bg_help_circle"
                            android:layout_marginStart="6dp" />
                    </LinearLayout>

                    <Switch
                        android:id="@+id/switchQrOnly"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:checked="true" />
                </LinearLayout>

                <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#F0F0F0" />

                <!-- 连续自动对焦 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <TextView
                            android:id="@+id/tvAutoFocus"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="连续自动对焦"
                            android:textColor="#212121"
                            android:textSize="15sp"
                            android:clickable="true"
                            android:focusable="true" />

                        <TextView
                            android:id="@+id/btnHelpAutoFocus"
                            android:layout_width="16dp"
                            android:layout_height="16dp"
                            android:text="?"
                            android:textColor="#9E9E9E"
                            android:textSize="10sp"
                            android:gravity="center"
                            android:background="@drawable/bg_help_circle"
                            android:layout_marginStart="6dp" />
                    </LinearLayout>

                    <Switch
                        android:id="@+id/switchAutoFocus"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:checked="true" />
                </LinearLayout>

                <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#F0F0F0" />

                <!-- 扫描区域提示 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <TextView
                            android:id="@+id/tvOverlay"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="扫描区域提示"
                            android:textColor="#212121"
                            android:textSize="15sp"
                            android:clickable="true"
                            android:focusable="true" />

                        <TextView
                            android:id="@+id/btnHelpOverlay"
                            android:layout_width="16dp"
                            android:layout_height="16dp"
                            android:text="?"
                            android:textColor="#9E9E9E"
                            android:textSize="10sp"
                            android:gravity="center"
                            android:background="@drawable/bg_help_circle"
                            android:layout_marginStart="6dp" />
                    </LinearLayout>

                    <Switch
                        android:id="@+id/switchShowOverlay"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:checked="true" />
                </LinearLayout>
            </LinearLayout>

            <!-- 性能设置 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_card"
                android:padding="16dp"
                android:layout_marginBottom="12dp"
                android:elevation="1dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="性能设置"
                    android:textColor="#1976D2"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.08"
                    android:layout_marginBottom="4dp" />

                <!-- 分析分辨率 -->
                <LinearLayout
                    android:id="@+id/resolutionRow"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:clickable="true"
                    android:focusable="true">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <TextView
                            android:id="@+id/tvResolutionLabel"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="分析分辨率"
                            android:textColor="#212121"
                            android:textSize="15sp"
                            android:clickable="true"
                            android:focusable="true" />

                        <TextView
                            android:id="@+id/btnHelpResolution"
                            android:layout_width="16dp"
                            android:layout_height="16dp"
                            android:text="?"
                            android:textColor="#9E9E9E"
                            android:textSize="10sp"
                            android:gravity="center"
                            android:background="@drawable/bg_help_circle"
                            android:layout_marginStart="6dp" />
                    </LinearLayout>

                    <Spinner
                        android:id="@+id/spinnerResolution"
                        android:layout_width="wrap_content"
                        android:layout_height="36dp"
                        android:layout_marginStart="8dp"
                        android:background="@drawable/bg_spinner"
                        android:popupBackground="@drawable/bg_spinner_dropdown"
                        android:dropDownWidth="wrap_content"
                        android:dropDownVerticalOffset="3dp"
                        android:spinnerMode="dropdown"
                        android:overlapAnchor="false" />
                </LinearLayout>
            </LinearLayout>

            <!-- 进度卡片设置 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_card"
                android:padding="16dp"
                android:layout_marginBottom="12dp"
                android:elevation="1dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="进度卡片"
                    android:textColor="#1976D2"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.08"
                    android:layout_marginBottom="4dp" />

                <!-- 始终显示进度卡片 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <TextView
                            android:id="@+id/tvAlwaysShowLabel"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="始终显示进度卡片"
                            android:textColor="#212121"
                            android:textSize="15sp"
                            android:clickable="true"
                            android:focusable="true" />

                        <TextView
                            android:id="@+id/btnHelpAlwaysShow"
                            android:layout_width="16dp"
                            android:layout_height="16dp"
                            android:text="?"
                            android:textColor="#9E9E9E"
                            android:textSize="10sp"
                            android:gravity="center"
                            android:background="@drawable/bg_help_circle"
                            android:layout_marginStart="6dp" />
                    </LinearLayout>

                    <Switch
                        android:id="@+id/switchAlwaysShowProgress"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:checked="true" />
                </LinearLayout>

                <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#F0F0F0" />

                <!-- 解码时显示进度卡片 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <TextView
                            android:id="@+id/tvProgressLabel"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="解码时显示进度卡片"
                            android:textColor="#212121"
                            android:textSize="15sp"
                            android:clickable="true"
                            android:focusable="true" />

                        <TextView
                            android:id="@+id/btnHelpProgress"
                            android:layout_width="16dp"
                            android:layout_height="16dp"
                            android:text="?"
                            android:textColor="#9E9E9E"
                            android:textSize="10sp"
                            android:gravity="center"
                            android:background="@drawable/bg_help_circle"
                            android:layout_marginStart="6dp" />
                    </LinearLayout>

                    <Switch
                        android:id="@+id/switchShowProgress"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:checked="true" />
                </LinearLayout>
            </LinearLayout>

            <!-- 关于 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_card"
                android:padding="20dp"
                android:layout_marginBottom="12dp"
                android:elevation="1dp"
                android:gravity="center">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="TXQR 接收器"
                    android:textColor="#212121"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="v4.0.0 · 离线二维码文件传输"
                    android:textColor="#9E9E9E"
                    android:textSize="12sp"
                    android:layout_marginTop="4dp" />

                <View
                    android:layout_width="40dp"
                    android:layout_height="1dp"
                    android:background="#E0E0E0"
                    android:layout_marginTop="12dp"
                    android:layout_marginBottom="8dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="作者: Kkwans"
                    android:textColor="#757575"
                    android:textSize="12sp" />

                <TextView
                    android:id="@+id/tvGithub"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="GitHub: Kkwans/txqr-android"
                    android:textColor="#1976D2"
                    android:textSize="12sp"
                    android:layout_marginTop="4dp"
                    android:clickable="true"
                    android:focusable="true" />
            </LinearLayout>

        </LinearLayout>
    </ScrollView>

</LinearLayout>
