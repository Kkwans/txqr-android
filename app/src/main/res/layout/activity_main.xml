<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#00000000"
    android:fitsSystemWindows="false">

    <!-- 相机预览 -->
    <androidx.camera.view.PreviewView
        android:id="@+id/previewView"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <!-- 叠加层 -->
    <com.txqr.reader.OverlayView
        android:id="@+id/overlayView"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <!-- 顶部状态栏 -->
    <LinearLayout
        android:id="@+id/topBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:minHeight="44dp"
        android:background="#99000000"
        android:gravity="center_vertical"
        android:paddingHorizontal="16dp"
        android:paddingVertical="6dp"
        android:layout_gravity="top">

        <TextView
            android:id="@+id/statusText"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="将摄像头对准二维码动画"
            android:textColor="#FFFFFF"
            android:textSize="15sp" />

        <TextView
            android:id="@+id/frameCountText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#CCFFFFFF"
            android:textSize="13sp" />

        <ImageButton
            android:id="@+id/btnSettings"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:layout_marginStart="10dp"
            android:background="@android:color/transparent"
            android:src="@drawable/ic_settings"
            android:tint="#FFFFFF"
            android:scaleType="center"
            android:padding="4dp"
            android:contentDescription="设置" />
    </LinearLayout>

    <!-- 进度信息卡片（底部，毛玻璃效果） -->
    <LinearLayout
        android:id="@+id/progressCard"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:layout_marginHorizontal="12dp"
        android:layout_marginBottom="24dp"
        android:orientation="vertical"
        android:background="@drawable/bg_card_blur"
        android:padding="16dp"
        android:elevation="8dp"
        android:visibility="gone">

        <!-- 进度标题 + 文件信息 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="8dp">

            <View
                android:layout_width="10dp"
                android:layout_height="10dp"
                android:background="@drawable/dot_indicator" />

            <TextView
                android:id="@+id/progressTitle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="  正在解码"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:textStyle="bold"
                android:layout_marginStart="6dp" />

            <TextView
                android:id="@+id/fileInfo"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=""
                android:textColor="#80FFFFFF"
                android:textSize="12sp" />
        </LinearLayout>

        <!-- 渐变进度条 -->
        <ProgressBar
            android:id="@+id/progressBar"
            style="@android:style/Widget.ProgressBar.Horizontal"
            android:layout_width="match_parent"
            android:layout_height="8dp"
            android:max="100"
            android:progress="0"
            android:progressDrawable="@drawable/progress_bar_gradient"
            android:layout_marginTop="10dp"
            android:layout_marginBottom="12dp" />

        <!-- 进度百分比 + 帧数 -->
        <TextView
            android:id="@+id/progressPercent"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="0% | 0/0 帧"
            android:textColor="#FFFFFF"
            android:textSize="15sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />

        <!-- 解码器状态 -->
        <TextView
            android:id="@+id/decoderStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="解码器: 就绪 | 摄像头: 就绪"
            android:textColor="#99FFFFFF"
            android:textSize="12sp"
            android:layout_marginBottom="4dp" />

        <!-- 诊断信息 -->
        <TextView
            android:id="@+id/diagnosticInfo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="诊断: 0 新帧 | 0 重复 | 0% 唯一"
            android:textColor="#66FFFFFF"
            android:textSize="11sp"
            android:layout_marginBottom="14dp" />

        <!-- 重新开始 / 停止按钮 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btnRestart"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="1"
                android:text="重新开始"
                android:textSize="13sp"
                android:backgroundTint="#66FFFFFF"
                android:textColor="#FFFFFF"
                android:layout_marginEnd="6dp" />

            <Button
                android:id="@+id/btnStop"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="1"
                android:text="停止扫描"
                android:textSize="13sp"
                android:backgroundTint="#33FF5252"
                android:textColor="#FF5252"
                android:layout_marginStart="6dp" />
        </LinearLayout>
    </LinearLayout>

    <!-- 结果面板（底部） -->
    <LinearLayout
        android:id="@+id/resultPanel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:orientation="vertical"
        android:background="@drawable/bg_card_blur"
        android:padding="20dp"
        android:layout_marginHorizontal="12dp"
        android:layout_marginBottom="24dp"
        android:elevation="8dp"
        android:visibility="gone">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="✅ 解码完成"
            android:textSize="17sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:gravity="center"
            android:layout_marginBottom="16dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btnOpenFile"
                android:layout_width="0dp"
                android:layout_height="46dp"
                android:layout_weight="1"
                android:text="📄 打开文件"
                android:textSize="14sp"
                android:backgroundTint="#1976D2"
                android:textColor="#FFFFFF"
                android:layout_marginEnd="6dp" />

            <Button
                android:id="@+id/btnOpenDir"
                android:layout_width="0dp"
                android:layout_height="46dp"
                android:layout_weight="1"
                android:text="📂 打开目录"
                android:textSize="14sp"
                android:backgroundTint="#388E3C"
                android:textColor="#FFFFFF"
                android:layout_marginStart="6dp" />
        </LinearLayout>

        <Button
            android:id="@+id/btnNextFile"
            android:layout_width="match_parent"
            android:layout_height="42dp"
            android:layout_marginTop="8dp"
            android:text="🔄 继续扫描"
            android:textSize="14sp"
            android:backgroundTint="#33FFFFFF"
            android:textColor="#FFFFFF" />
    </LinearLayout>

</FrameLayout>
