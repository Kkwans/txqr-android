<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5">

    <!-- 相机预览 -->
    <androidx.camera.view.PreviewView
        android:id="@+id/previewView"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <!-- 叠加层 -->
    <com.txqr.reader.OverlayView
        android:id="@+id/overlayView"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <!-- 顶部状态栏 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:background="#99000000"
        android:gravity="center_vertical"
        android:paddingHorizontal="16dp"
        android:layout_gravity="top">

        <TextView
            android:id="@+id/statusText"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="将摄像头对准二维码动画"
            android:textColor="#FFFFFF"
            android:textSize="15sp" />

        <TextView
            android:id="@+id/frameCountText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#CCFFFFFF"
            android:textSize="13sp" />

        <ImageButton
            android:id="@+id/btnSettings"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:layout_marginStart="10dp"
            android:background="@android:color/transparent"
            android:src="@android:drawable/ic_menu_manage"
            android:tint="#FFFFFF"
            android:scaleType="center"
            android:padding="4dp"
            android:contentDescription="设置" />
    </LinearLayout>

    <!-- 底部提示 -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|center_horizontal"
        android:layout_marginBottom="12dp"
        android:text="💡 支持放大手势 · 点击对焦"
        android:textColor="#CCFFFFFF"
        android:textSize="12sp"
        android:background="#66000000"
        android:paddingHorizontal="14dp"
        android:paddingVertical="6dp" />

    <!-- 进度信息卡片（解码中显示） -->
    <LinearLayout
        android:id="@+id/progressCard"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:layout_marginHorizontal="20dp"
        android:orientation="vertical"
        android:background="@drawable/bg_card"
        android:padding="20dp"
        android:elevation="8dp"
        android:visibility="gone">

        <!-- 进度标题 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="8dp">

            <View
                android:layout_width="10dp"
                android:layout_height="10dp"
                android:background="#2962FF" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="  进度"
                android:textColor="#212121"
                android:textSize="14sp"
                android:textStyle="bold"
                android:fontFamily="monospace" />
        </LinearLayout>

        <!-- 进度条 -->
        <ProgressBar
            android:id="@+id/progressBar"
            style="@android:style/Widget.ProgressBar.Horizontal"
            android:layout_width="match_parent"
            android:layout_height="8dp"
            android:max="100"
            android:progress="0"
            android:progressDrawable="@drawable/progress_bar_custom"
            android:layout_marginBottom="12dp" />

        <!-- 进度百分比 -->
        <TextView
            android:id="@+id/progressPercent"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="0% | 0/0 帧已接收"
            android:textColor="#333333"
            android:textSize="15sp"
            android:fontFamily="monospace"
            android:layout_marginBottom="8dp" />

        <!-- 解码器状态 -->
        <TextView
            android:id="@+id/decoderStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="解码器: 就绪 | 摄像头: 就绪"
            android:textColor="#666666"
            android:textSize="13sp"
            android:fontFamily="monospace"
            android:layout_marginBottom="8dp" />

        <!-- 诊断信息 -->
        <TextView
            android:id="@+id/diagnosticInfo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="诊断: 0 新帧 | 0 重复 | 0% 唯一 | 0 恢复"
            android:textColor="#666666"
            android:textSize="12sp"
            android:fontFamily="monospace" />
    </LinearLayout>

    <!-- 结果面板（解码完成后显示） -->
    <LinearLayout
        android:id="@+id/resultPanel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:orientation="vertical"
        android:background="@drawable/bg_card"
        android:padding="20dp"
        android:layout_marginHorizontal="12dp"
        android:layout_marginBottom="12dp"
        android:elevation="8dp"
        android:visibility="gone">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="✅ 解码完成"
            android:textSize="17sp"
            android:textStyle="bold"
            android:textColor="#212121"
            android:gravity="center"
            android:layout_marginBottom="16dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btnOpenFile"
                android:layout_width="0dp"
                android:layout_height="46dp"
                android:layout_weight="1"
                android:text="📄 打开文件"
                android:textSize="14sp"
                android:backgroundTint="#1976D2"
                android:textColor="#FFFFFF"
                android:layout_marginEnd="6dp" />

            <Button
                android:id="@+id/btnOpenDir"
                android:layout_width="0dp"
                android:layout_height="46dp"
                android:layout_weight="1"
                android:text="📂 打开目录"
                android:textSize="14sp"
                android:backgroundTint="#388E3C"
                android:textColor="#FFFFFF"
                android:layout_marginStart="6dp" />
        </LinearLayout>

        <Button
            android:id="@+id/btnNextFile"
            android:layout_width="match_parent"
            android:layout_height="42dp"
            android:layout_marginTop="8dp"
            android:text="🔄 继续扫描"
            android:textSize="14sp"
            android:backgroundTint="#F0F0F0"
            android:textColor="#616161" />
    </LinearLayout>

</FrameLayout>
